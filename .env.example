# Scaleway CLI Configuration
# Copy this file to .env and fill in your credentials
# Then run: source .env && ./run-scw.sh [command]

# Your Scaleway access key (required for API calls)
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX

# Your Scaleway secret key (required for API calls)
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your default organization ID (find it in the Scaleway console)
SCW_DEFAULT_ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default region (e.g., fr-par, nl-ams, pl-waw)
SCW_DEFAULT_REGION=fr-par

# Default zone (e.g., fr-par-1, nl-ams-1)
SCW_DEFAULT_ZONE=fr-par-1

# Optional: Configuration profile name
# SCW_PROFILE=default

# Optional: Custom config file path
# SCW_CONFIG_PATH=/workspace/.scwrc

# Optional: Override container image
# SCW_RUNNER_IMAGE=scaleway/cli:latest

# Optional: Force container runtime ("podman" or "docker")
# SCW_RUNNER_RUNTIME=podman
